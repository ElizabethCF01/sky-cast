{
  "name": "skycast",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "imports": {
    "#design/*": "./src/shared/design/*/index.ts",
    "#shared/*": "./src/shared/*.ts"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:ci": "jest --ci",
    "build": "expo export --platform ios --platform android",
    "lint": "pnpm run lint-typecheck && pnpm run lint-eslint && pnpm run lint-prettier && pnpm run lint-knip",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg))"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.8",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.13",
    "expo-location": "~56.0.15",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@christopherjbaker/eslint-config": "^3.1.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.16",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true
}
